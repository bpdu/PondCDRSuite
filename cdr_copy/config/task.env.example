# cdr_copy task configuration
# Copy this file to config/<task_name>.env and fill in the parameters

# ============================================
# REQUIRED PARAMETERS
# ============================================

# Source folder with files (required)
from="/path/to/source/folder"

# Destination folder for copying (required)
to="/path/to/destination/folder"

# ============================================
# FILTERING
# ============================================

# Filter by company (optional)
# Copies only files with the specified substring in the company name
# Example: company="Telna" will find LIVE_Telna_Corp_CDR_...
# Leave empty to copy all companies
#company=""

# ============================================
# STRUCTURE FLAGS
# ============================================

# Organize files into company folders (optional)
# Extracts company from filename and replaces underscores with spaces
# Example: LIVE_Telna_Corp_CDR_... → Telna Corp/file.csv
by_company=no

# Organize files into date folders (optional)
# Extracts date from filename in YYYY-MM-DD format
# Example: 2026-04-10/file.csv
by_date=no

# Flat structure from subfolders (optional)
# Recursively scans source folder and copies all files into a flat structure
flat=no

# ============================================
# DATE FILTERING
# ============================================

# Only yesterday's files (optional)
# Sets from_date and to_date to yesterday
yesterday=no

# Only today's files (optional)
# Sets from_date and to_date to today
today=no

# Date range - start date (optional)
# Format: YYYYMMDD
# Ignores files before this date
#from_date=""

# Date range - end date (optional)
# Format: YYYYMMDD
# Ignores files after this date
#to_date=""

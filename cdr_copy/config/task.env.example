# Конфигурация задачи cdr_copy
# Скопируйте этот файл в config/<имя_задачи>.env и заполните параметры

# ============================================
# ОБЯЗАТЕЛЬНЫЕ ПАРАМЕТРЫ
# ============================================

# Исходная папка с файлами (обязательно)
from="/path/to/source/folder"

# Целевая папка для копирования (обязательно)
to="/path/to/destination/folder"

# ============================================
# ФИЛЬТРАЦИЯ
# ============================================

# Фильтрация по компании (опционально)
# Копирует только файлы с указанной подстрокой в названии компании
# Пример: company="Telna" найдёт LIVE_Telna_Corp_CDR_...
# Оставьте пустым для копирования всех компаний
#company=""

# ============================================
# ФЛАГИ СТРУКТУРЫ
# ============================================

# Раскладывать файлы по папкам компаний (опционально)
# Извлекает компанию из имени файла и заменяет подчёркивания на пробелы
# Пример: LIVE_Telna_Corp_CDR_... → Telna Corp/file.csv
by_company=no

# Раскладывать файлы по папкам дат (опционально)
# Извлекает дату из имени файла в формате YYYY-MM-DD
# Пример: 2026-04-10/file.csv
by_date=no

# Плоская структура из подпапок (опционально)
# Рекурсивно сканирует исходную папку и копирует все файлы в плоскую структуру
flat=no

# ============================================
# ФИЛЬТРАЦИЯ ПО ДАТАМ
# ============================================

# Только вчерашние файлы (опционально)
# Устанавливает from_date и to_date на вчерашний день
yesterday=no

# Только сегодняшние файлы (опционально)
# Устанавливает from_date и to_date на сегодняшний день
today=no

# Диапазон дат - начальная дата (опционально)
# Формат: YYYYMMDD
# Игнорирует файлы до этой даты
#from_date=""

# Диапазон дат - конечная дата (опционально)
# Формат: YYYYMMDD
# Игнорирует файлы после этой даты
#to_date=""

# CDR Organizer - Process incoming files every 5 minutes
# Place this file in /etc/cron.d/cdr_organize

PATH=/usr/local/sbin:/usr/local/bin:/sbin:/bin:/usr/sbin:/usr/bin

*/5 * * * * {USER} python3 {PROJECT_DIR}/cdr_organize/cdr_organize.py /home/cdr_admin/CDRs/inbound/telna_cdr /home/cdr_admin/CDRs/outbound
*/5 * * * * {USER} python3 {PROJECT_DIR}/cdr_organize/cdr_organize.py /home/cdr_admin/CDRs/inbound/telna_lu /home/cdr_admin/CDRs/outbound
